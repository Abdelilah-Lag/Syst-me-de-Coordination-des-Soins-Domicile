    {
      "name": "4. Tracking Service - Création Visite",
      "item": [
        {
          "name": "Créer Visite à suivre",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "http://localhost:8084/tracking/visits?patientId={{patientId}}&caregiverId={{caregiverId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8084",
              "path": ["tracking", "visits"],
              "query": [
                {
                  "key": "patientId",
                  "value": "{{patientId}}"
                },
                {
                  "key": "caregiverId",
                  "value": "{{caregiverId}}"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Visite créée avec succès\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const response = pm.response.json();",
                  "  pm.expect(response.visitId).to.not.be.null;",
                  "  pm.environment.set(\"visitId\", response.visitId);",
                  "  console.log(\"Visite créée avec ID: \" + response.visitId);",
                  "});"
