    {
      "name": "5. Visit Optimization Service - Optimisation",
      "item": [
        {
          "name": "Calculer Distance entre Points GPS (Haversine)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8083/visits/distance?lat1=48.8566&lon1=2.3522&lat2=48.8419&lon2=2.3012",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["visits", "distance"],
              "query": [
                {
                  "key": "lat1",
                  "value": "48.8566"
                },
                {
                  "key": "lon1",
                  "value": "2.3522"
                },
                {
                  "key": "lat2",
                  "value": "48.8419"
                },
                {
                  "key": "lon2",
                  "value": "2.3012"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Optimiser Tournée Soignant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"patientId\": {{patientId}},\n    \"caregiverId\": {{caregiverId}},\n    \"date\": \"2026-04-30\",\n    \"heurePreferee\": {\"hour\": 10, \"minute\": 0},\n    \"dureeMinutes\": 60,\n    \"patientLatitude\": 48.8566,\n    \"patientLongitude\": 2.3522,\n    \"typeVisite\": \"SOIN_SPECIALISE\"\n  }\n]"
            },
            "url": {
              "raw": "http://localhost:8083/visits/optimize/{{caregiverId}}?date=2026-04-30",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8083",
              "path": ["visits", "optimize", "{{caregiverId}}"],
              "query": [
                {
                  "key": "date",
                  "value": "2026-04-30"
                }
              ]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Optimisation réussie\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const response = pm.response.json();",
                  "  pm.expect(response.distanceTotaleKm).to.be.a('number');",
                  "  pm.expect(response.nombreVisites).to.be.gt(0);",
                  "  console.log(\"Tournée optimisée: \" + response.nombreVisites + \" visites, \" + response.distanceTotaleKm + \" km\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
