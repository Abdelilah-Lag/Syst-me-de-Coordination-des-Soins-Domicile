    {
      "name": "2. Patient Service - Création Patient",
      "item": [
        {
          "name": "Créer Patient (Avec GPS)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Martin\",\n  \"prenom\": \"Sophie\",\n  \"dateNaissance\": \"1945-03-15\",\n  \"telephone\": \"0612345678\",\n  \"email\": \"sophie.martin@email.com\",\n  \"adresse\": \"12 Rue des Lilas, 75001 Paris\",\n  \"latitude\": 48.8566,\n  \"longitude\": 2.3522,\n  \"niveauDependance\": \"DEPENDANT\",\n  \"pathologies\": \"Hypertension, Arthrose\",\n  \"besoinsSpecifiques\": \"Aide à la mobilité\",\n  \"contraintes\": \"Disponible après 9h\",\n  \"nomAidant\": \"Pierre Martin\",\n  \"telephoneAidant\": \"0698765432\",\n  \"statut\": \"ACTIF\"\n}"
            },
            "url": {
              "raw": "http://localhost:8081/patients",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["patients"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Patient créé avec succès\", () => {",
                  "  pm.response.to.have.status(200);",
                  "  const response = pm.response.json();",
                  "  pm.expect(response.id).to.not.be.null;",
                  "  pm.environment.set(\"patientId\", response.id.toString());",
                  "  console.log(\"Patient créé avec ID: \" + response.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Obtenir Patient par ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8081/patients/{{patientId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8081",
              "path": ["patients", "{{patientId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Lister tous les Patients",
          "request": {
            "method": "GET",
